{
  "name": "tooldi-agent-runtime",
  "version": "0.0.0",
  "private": true,
  "description": "Tooldi natural-language agent backend runtime v1 workspace",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=24.11.0",
    "pnpm": ">=10.28.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "clean": "pnpm -r --if-present clean",
    "dev": "pnpm -r --parallel --if-present dev",
    "lint": "pnpm -r --if-present lint",
    "local:toolditor:api": "./scripts/start-local-api-toolditor.sh",
    "local:toolditor:stack": "./scripts/start-local-toolditor-stack.sh",
    "local:toolditor:stack:real": "./scripts/start-local-toolditor-real-stack.sh",
    "local:toolditor:worker": "./scripts/start-local-worker-toolditor.sh",
    "local:toolditor:worker:real": "./scripts/start-local-worker-toolditor-real.sh",
    "smoke:retry": "pnpm build && node --enable-source-maps ./scripts/smoke-retry.mjs",
    "smoke:transport": "pnpm build && node --enable-source-maps ./scripts/smoke-transport.mjs",
    "test": "pnpm build && pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "format:check": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0"
  }
}
